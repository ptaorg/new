{
  "name": "ptaorg-github-io",
  "private": true,
  "scripts": {
    "test": "npm run check:site && npm run check:site-js-version",
    "check:site": "node tools/check-site.mjs",
    "check:generated": "node scripts/check-generated-files.js",
    "check:site-js-version": "node scripts/check-site-js-version.js 90",
    "check:all": "npm run check:site && npm run check:generated && npm run check:site-js-version",
    "report:site-js-version": "node scripts/report-site-js-version.js",
    "sync:materials": "node scripts/sync-school-materials.js --dry-run",
    "sync:materials:write": "node scripts/sync-school-materials.js --write",
    "generate:schools": "node scripts/generate-school-pages.js",
    "generate:archive": "node scripts/generate-national-archive.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:search": "node scripts/generate-search-index.js",
    "maintenance:ensure-home-role-anchor": "node scripts/add-home-audience-gateway.js",
    "maintenance:add-home-audience-gateway": "npm run maintenance:ensure-home-role-anchor",
    "maintenance:update-home-date": "node scripts/update-home-last-updated.js",
    "maintenance:bump-site-js:dry-run": "node scripts/bump-site-js-version.js 90 --dry-run",
    "maintenance:bump-site-js": "node scripts/bump-site-js-version.js",
    "maintenance:bump-site-js:check": "npm run maintenance:bump-site-js -- 90 && npm run check:site-js-version",
    "maintenance:site-js-cache": "npm run report:site-js-version && npm run maintenance:bump-site-js:dry-run && npm run maintenance:bump-site-js:check && npm run report:site-js-version && npm run check:all"
  }
}
